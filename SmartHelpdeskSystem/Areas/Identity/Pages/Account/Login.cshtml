@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Smart Helpdesk</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="linear-login-page">

    <div class="linear-glow glow-one"></div>
    <div class="linear-glow glow-two"></div>

    <div class="linear-login-card">

        <div class="linear-logo">💬</div>

        <h1>Smart Helpdesk</h1>
        <p>Welcome back. Login to manage your support workspace.</p>

        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="linear-field">
                <input asp-for="Input.Email"
                       autocomplete="off"
                       placeholder="Email address" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="linear-field">
                <input asp-for="Input.Password"
                       autocomplete="off"
                       placeholder="Password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="linear-options">
                <label>
                    <input asp-for="Input.RememberMe" />
                    Remember me
                </label>

                <a asp-page="./ForgotPassword">Forgot?</a>
            </div>

            <button id="login-submit" type="submit" class="linear-login-btn">
                Login
            </button>

        </form>

        <div class="linear-register">
            New to Smart Helpdesk?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                Create account
            </a>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

</body>
</html>