@model SmartHelpdeskSystem.Models.Status

@{
    ViewData["Title"] = "Create Status";
}

<div class="page-header">
    <div>
        <h1>📌 Create Status</h1>
        <p>Add a new ticket status to the helpdesk workflow.</p>
    </div>
</div>

<div class="form-card">

    <form asp-action="Create">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3"></div>

        <div class="mb-4">

            <label asp-for="StatusName"
                   class="form-label fw-bold">
                Status Name
            </label>

            <input asp-for="StatusName"
                   class="form-control form-control-lg"
                   placeholder="Open, In Progress, Resolved, Closed..." />

            <span asp-validation-for="StatusName"
                  class="text-danger"></span>

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary">
                📌 Create Status
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}