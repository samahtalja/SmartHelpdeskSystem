@model IEnumerable<SmartHelpdeskSystem.Models.Status>

@{
    ViewData["Title"] = "Statuses";
}

<div class="page-header">
    <div>
        <h1>📌 Ticket Statuses</h1>
        <p>Manage all ticket statuses used in the helpdesk system.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        ➕ New Status
    </a>
</div>

<div class="table-card">

    <table class="table align-middle">
        <thead>
            <tr>
                <th>Status Name</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.StatusName</strong>
                        </td>

                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@item.StatusId"
                               class="btn btn-sm btn-outline-warning">
                                Edit
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.StatusId"
                               class="btn btn-sm btn-outline-primary">
                                Details
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.StatusId"
                               class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>

                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" class="text-center text-muted py-4">
                        No statuses found.
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>