@model SmartHelpdeskSystem.Models.Status

@{
    ViewData["Title"] = "Edit Status";
}

<div class="page-header">
    <div>
        <h1>✏️ Edit Status</h1>
        <p>Update status information in the helpdesk workflow.</p>
    </div>
</div>

<div class="form-card">

    <form asp-action="Edit">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3"></div>

        <input type="hidden" asp-for="StatusId" />

        <div class="mb-4">

            <label asp-for="StatusName"
                   class="form-label fw-bold">
                Status Name
            </label>

            <input asp-for="StatusName"
                   class="form-control form-control-lg"
                   placeholder="Open, In Progress, Resolved, Closed..." />

            <span asp-validation-for="StatusName"
                  class="text-danger"></span>

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary">
                💾 Save Changes
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}