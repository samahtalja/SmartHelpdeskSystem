@model SmartHelpdeskSystem.Models.Priority

@{
    ViewData["Title"] = "Delete Priority";
}

<div class="page-header">
    <div>
        <h1>🗑️ Delete Priority</h1>
        <p>Remove a priority level from the helpdesk system.</p>
    </div>
</div>

<div class="form-card">

    <div class="alert alert-danger mb-4">
        <h5 class="mb-2">⚠ Warning</h5>
        <p class="mb-0">
            Are you sure you want to delete this priority?
            This action cannot be undone.
        </p>
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">
            Priority Name
        </label>

        @{
            string badgeClass = Model.PriorityName?.ToLower() switch
            {
                "high" => "bg-danger",
                "medium" => "bg-warning text-dark",
                "low" => "bg-success",
                _ => "bg-primary"
            };
        }

        <div class="mt-2">
            <span class="badge @badgeClass fs-6 p-2">
                @Model.PriorityName
            </span>
        </div>
    </div>

    <form asp-action="Delete">

        <input type="hidden" asp-for="PriorityId" />

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">
                🗑️ Delete Priority
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Cancel
            </a>
        </div>

    </form>

</div>