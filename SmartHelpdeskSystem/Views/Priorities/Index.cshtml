@model IEnumerable<SmartHelpdeskSystem.Models.Priority>

@{
    ViewData["Title"] = "Priorities";
}

<div class="page-header">
    <div>
        <h1>⚡ Ticket Priorities</h1>
        <p>Manage ticket priority levels in the helpdesk system.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        ➕ New Priority
    </a>
</div>

<div class="table-card">

    <table class="table align-middle">
        <thead>
            <tr>
                <th>Priority Name</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    string badgeClass = item.PriorityName?.ToLower() switch
                    {
                        "high" => "bg-danger",
                        "medium" => "bg-warning text-dark",
                        "low" => "bg-success",
                        _ => "bg-primary"
                    };

                    <tr>
                        <td>
                            <span class="badge @badgeClass">
                                @item.PriorityName
                            </span>
                        </td>

                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@item.PriorityId"
                               class="btn btn-sm btn-outline-warning">
                                Edit
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.PriorityId"
                               class="btn btn-sm btn-outline-primary">
                                Details
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.PriorityId"
                               class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>

                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" class="text-center text-muted py-4">
                        No priorities found.
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>