@model SmartHelpdeskSystem.Models.Priority

@{
    ViewData["Title"] = "Create Priority";
}

<div class="page-header">
    <div>
        <h1>⚡ Create Priority</h1>
        <p>Add a new priority level to the helpdesk system.</p>
    </div>
</div>

<div class="form-card">

    <form asp-action="Create">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3"></div>

        <div class="mb-4">

            <label asp-for="PriorityName"
                   class="form-label fw-bold">
                Priority Name
            </label>

            <input asp-for="PriorityName"
                   class="form-control form-control-lg"
                   placeholder="High, Medium, Low..." />

            <span asp-validation-for="PriorityName"
                  class="text-danger"></span>

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary">
                ⚡ Create Priority
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}