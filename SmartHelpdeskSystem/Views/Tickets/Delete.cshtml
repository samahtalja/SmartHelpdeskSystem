@model SmartHelpdeskSystem.Models.Ticket

@{
    ViewData["Title"] = "Delete Ticket";

    var priorityClass = Model.Priority?.PriorityName?.ToLower();
    var statusClass = Model.Status?.StatusName?.ToLower().Replace(" ", "-");
}

<div class="page-header">
    <div>
        <h1>🗑️ Delete Ticket</h1>
        <p>Remove a ticket from the helpdesk system.</p>
    </div>
</div>

<div class="form-card">

    <div class="alert alert-danger mb-4">
        <h5 class="mb-2">⚠ Warning</h5>
        <p class="mb-0">
            Are you sure you want to delete this ticket?
            This action cannot be undone.
        </p>
    </div>

    <div class="ticket-preview">

        <h3>@Model.Title</h3>

        <p class="ticket-description">
            @Model.Description
        </p>

        <div class="info-grid">

            <div class="info-item">
                <span>Category</span>
                <strong>@Model.Category?.CategoryName</strong>
            </div>

            <div class="info-item">
                <span>Priority</span>
                <strong>
                    <span class="badge-priority @priorityClass">
                        @Model.Priority?.PriorityName
                    </span>
                </strong>
            </div>

            <div class="info-item">
                <span>Status</span>
                <strong>
                    <span class="badge-status @statusClass">
                        @Model.Status?.StatusName
                    </span>
                </strong>
            </div>

            <div class="info-item">
                <span>Created At</span>
                <strong>
                    @Model.CreatedAt.ToString("yyyy-MM-dd")
                </strong>
            </div>

        </div>

    </div>

    <form asp-action="Delete" class="mt-4">

        <input type="hidden" asp-for="TicketId" />

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-danger">
                🗑️ Delete Ticket
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>